dist/

# Per-run artifacts directory — contains execution.log, report.json, and
# the ephemeral clone (workspace/) retained on FAILED runs.
# Prune manually when disk space is a concern: rm -rf dbflow-validator-runs/
dbflow-validator-runs/

# Built binary (local build via `go build` or `make build`).
/dbflow-validator

# Plugin jar (>100MB) — fetched from GitHub Packages at build time, not committed.
# Glob matches any version so a version bump never needs to touch this file.
internal/embedrepo/mvn-vendor/repository/com/gs/ftt/coe-ds/relational-db-release-manager-plugin/*/relational-db-release-manager-plugin-*.jar

# Local-only tooling and process artifacts — not part of the app's functionality.
# These are AI/SDD assistants and maintainer process docs, kept on disk but not versioned.
.engram/
.atl/
openspec/
docs/
